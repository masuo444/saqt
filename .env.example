# === SAQT 環境変数設定 ===
# このファイルを .env にコピーして値を入れてください
# cp .env.example .env

# --- Gmail SMTP（営業メール送信用）---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# ※ Googleアカウント → 2段階認証ON → アプリパスワード発行

# --- Gemini API（個別メール生成 + チャットボット用）---
GEMINI_API_KEY=your-gemini-api-key
# ※ https://aistudio.google.com/ で無料発行

# --- Google Maps API（リード自動収集用）---
# ※ なくても手動CSV入力で動作します
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
